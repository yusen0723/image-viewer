{
  "manifest_version": 3,
  "name": "Image Viewer",
  "version": "0.1.0",
  "description": "Open website images in an in-page viewer with zoom, drag, and gallery navigation.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "options_page": "src/options.html"
}
